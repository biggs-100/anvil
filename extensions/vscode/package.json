{
  "name": "anvil-vscode",
  "displayName": "Anvil",
  "description": "Reproducible development environments — manage runtimes, diagnostics, and context from VS Code",
  "version": "0.1.0",
  "publisher": "anvil",
  "license": "MIT",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onCommand:anvil.status",
    "onCommand:anvil.diagnose",
    "onCommand:anvil.explain",
    "onCommand:anvil.run",
    "onWorkspaceContains:anvil.toml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "anvil.status",
        "title": "Anvil: Show Status"
      },
      {
        "command": "anvil.diagnose",
        "title": "Anvil: Diagnose"
      },
      {
        "command": "anvil.explain",
        "title": "Anvil: Explain Runtime"
      },
      {
        "command": "anvil.run",
        "title": "Anvil: Run Command"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anvil",
          "title": "Anvil",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "anvil": [
        {
          "type": "tree",
          "id": "anvil.explorer",
          "name": "Anvil Explorer"
        }
      ]
    },
    "configuration": {
      "title": "Anvil",
      "properties": {
        "anvil.binaryPath": {
          "type": "string",
          "default": "anvil",
          "description": "Path or name of the anvil binary on PATH"
        },
        "anvil.healthPollInterval": {
          "type": "number",
          "default": 30000,
          "description": "Interval in milliseconds for health status polling (0 to disable)"
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json"
  }
}
