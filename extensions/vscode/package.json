{
  "name": "forge-vscode",
  "displayName": "Forge",
  "description": "Reproducible development environments — manage runtimes, diagnostics, and context from VS Code",
  "version": "0.1.0",
  "publisher": "forge",
  "license": "MIT",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onCommand:forge.status",
    "onCommand:forge.diagnose",
    "onCommand:forge.explain",
    "onCommand:forge.run",
    "onWorkspaceContains:forge.toml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "forge.status",
        "title": "Forge: Show Status"
      },
      {
        "command": "forge.diagnose",
        "title": "Forge: Diagnose"
      },
      {
        "command": "forge.explain",
        "title": "Forge: Explain Runtime"
      },
      {
        "command": "forge.run",
        "title": "Forge: Run Command"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forge",
          "title": "Forge",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "forge": [
        {
          "type": "tree",
          "id": "forge.explorer",
          "name": "Forge Explorer"
        }
      ]
    },
    "configuration": {
      "title": "Forge",
      "properties": {
        "forge.binaryPath": {
          "type": "string",
          "default": "forge",
          "description": "Path or name of the forge binary on PATH"
        },
        "forge.healthPollInterval": {
          "type": "number",
          "default": 30000,
          "description": "Interval in milliseconds for health status polling (0 to disable)"
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json"
  }
}
